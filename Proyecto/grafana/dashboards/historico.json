          "format": "table",
          "rawSql": "SELECT date(time) AS fecha, ROUND((SUM(COALESCE(pac,0))*5.0/3600.0/1000.0)::numeric, 2) AS \"kWh AC\", ROUND((SUM(COALESCE(ppv_total,0))*5.0/3600.0/1000.0)::numeric, 2) AS \"kWh DC\", ROUND(MAX(COALESCE(pac,0))::numeric, 0) AS \"Pico W\", ROUND(AVG(COALESCE(temp,0))::numeric, 1) AS \"Temp Avg\", ROUND(AVG(COALESCE(vac,0))::numeric, 1) AS \"Vac Avg\", ROUND(AVG(COALESCE(fac,0))::numeric, 2) AS \"Fac Avg\", SUM(CASE WHEN COALESCE(pac,0) > 0 THEN 1 ELSE 0 END)*5/60 AS \"Horas Prod\" FROM realtime WHERE $__timeFilter(time) AND inverter_id=1 AND is_stale = false GROUP BY 1 ORDER BY 1 DESC"
