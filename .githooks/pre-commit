#!/bin/bash
# pre-commit hook — Protege contra commit accidental de secretos.
# Detecta passwords hardcoded en archivos de configuración trackeados.
#
# Activar con:
#   git config core.hooksPath .githooks
# o copiar a .git/hooks/pre-commit y dar chmod +x.

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND=0

for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.env|*.env.*|secrets/*)
            echo -e "${RED}ERROR: Archivo sensible intentando commitearse: $FILE${NC}"
            FOUND=1
            ;;
    esac
done

# Detectar passwords hardcoded. Filtra por línea:
#   1) Comentarios (# al inicio)
#   2) Lineas con ${VAR} (interpolación de variable)
#   3) Lineas con os.environ.get(...), os.getenv(...), os.environ[...]
#   4) Defaults conocidos: 'solar', 'changeme', 'placeholder'
#   5) Lineas con marcadores de placeholder (xxx, example, TODO, FIXME)
for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.yml|*.yaml|*.json|*.sh|*.py|*.ini|*.toml|*.cfg)
            if [ ! -f "$FILE" ]; then
                continue
            fi
            # Filtrar el contenido
            SUSPICIOUS=$(grep -n -E -i '(password|passwd|pwd|secret|api_key|token)\s*[:=]\s*["'\'']?[A-Za-z0-9+/=._-]{8,}' "$FILE" 2>/dev/null \
                | awk -F: '
                    {
                        line = $0
                        sub(/^[0-9]+:/, "", line)
                        # Saltar comentarios
                        if (line ~ /^[[:space:]]*#/) next
                        # Saltar interpolación de variable o uso directo de variable como valor
                        if (line ~ /\$\{?[A-Z_]+\}?/) next
                        if (line ~ /password\s*=\s*[A-Z_][A-Z0-9_]+/) next
                        # Saltar uso de os.environ
                        if (line ~ /os\.environ|getenv\(/) next
                        # Saltar defaults conocidos
                        if (line ~ /'"'"'solar'"'"'|"solar"|'"'"'changeme'"'"'|"changeme"/) next
                        # Saltar marcadores de placeholder
                        if (line ~ /placeholder|xxx|example|TODO|FIXME/) next
                        print
                    }
                ')
            if [ -n "$SUSPICIOUS" ]; then
                echo -e "${YELLOW}ADVERTENCIA: Posible password hardcoded en $FILE${NC}"
                echo "Revisar manualmente:"
                echo "$SUSPICIOUS" | head -3
                echo ""
                FOUND=1
            fi
            ;;
    esac
done

if [ $FOUND -eq 1 ]; then
    echo -e "${RED}Commit bloqueado.${NC}"
    echo "Si estás seguro de que no es un secreto, usa: git commit --no-verify"
    exit 1
fi

exit 0
