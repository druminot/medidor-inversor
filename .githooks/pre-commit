#!/bin/bash
# pre-commit hook — Protege contra commit accidental de secretos.
# Detecta passwords comunes en archivos tracked.
#
# Activar con:
#   git config core.hooksPath .githooks
# o copiar a .git/hooks/pre-commit y dar chmod +x.

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND=0

for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.env|*.env.*|secrets/*)
            echo -e "${RED}ERROR: Archivo sensible intentando commitearse: $FILE${NC}"
            FOUND=1
            ;;
    esac
done

# Detectar passwords hardcoded en archivos de configuración trackeados
for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.yml|*.yaml|*.json|*.sh|*.py|*.ini|*.toml|*.cfg)
            if [ ! -f "$FILE" ]; then
                continue
            fi
            # Patrones comunes: PASSWORD = "..."  /  password: "..."  /  - password=...
            if grep -E -i '(password|passwd|pwd|secret|api_key|token)\s*[:=]\s*["'\'']?[A-Za-z0-9+/=._-]{8,}' "$FILE" 2>/dev/null | grep -v -E '^[[:space:]]*#' | grep -v -E '\$\{?[A-Z_]+\}?' | grep -v -E 'changeme|placeholder|xxx|example|test' > /dev/null; then
                echo -e "${YELLOW}ADVERTENCIA: Posible password hardcoded en $FILE${NC}"
                echo "Revisar manualmente:"
                grep -E -i '(password|passwd|pwd|secret|api_key|token)\s*[:=]\s*["'\'']?[A-Za-z0-9+/=._-]{8,}' "$FILE" | head -3
                echo ""
                FOUND=1
            fi
            ;;
    esac
done

if [ $FOUND -eq 1 ]; then
    echo -e "${RED}Commit bloqueado.${NC}"
    echo "Si estás seguro de que no es un secreto, usa: git commit --no-verify"
    exit 1
fi

exit 0
