      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT CASE WHEN NOT EXISTS (SELECT 1 FROM realtime_clean WHERE inverter_id=1 AND time > NOW() - INTERVAL '5 minutes') THEN 0 WHEN EXISTS (SELECT 1 FROM realtime_clean WHERE inverter_id=1 AND time > NOW() - INTERVAL '2 minutes' AND status = 1 AND COALESCE(pac,0) > 0) THEN 3 WHEN EXISTS (SELECT 1 FROM realtime_clean WHERE inverter_id=1 AND time > NOW() - INTERVAL '2 minutes' AND (COALESCE(vpv,0) > 0 OR COALESCE(vpv1,0) > 0 OR COALESCE(vpv2,0) > 0 OR COALESCE(vpv3,0) > 0)) THEN 2 ELSE 1 END AS periodo"
        }
      ],
      "title": "Periodo",
      "type": "stat"
    },
