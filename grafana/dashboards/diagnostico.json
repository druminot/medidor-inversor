      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT time AT TIME ZONE 'America/Argentina/Buenos_Aires' AS hora, CASE status WHEN 0 THEN 'Esperando' WHEN 1 THEN 'Normal' WHEN 2 THEN 'Falla' WHEN 3 THEN 'Falla Perm.' ELSE 'Desconocido' END AS estado, CASE WHEN is_stale THEN 'SIN DATOS' ELSE 'OK' END AS señal, ROUND(COALESCE(vac,0)::numeric, 1) AS \"Vac\", ROUND(COALESCE(fac,0)::numeric, 2) AS \"Fac\", ROUND(COALESCE(temp,0)::numeric, 1) AS \"Temp\", ROUND(COALESCE(ppv_total,0)::numeric, 0) AS \"Pdc W\", ROUND(COALESCE(pac,0)::numeric, 0) AS \"Pac W\" FROM realtime WHERE $__timeFilter(time) AND inverter_id=1 AND (status != 1 OR COALESCE(status, 0) != LAG(COALESCE(status, 0)) OVER (ORDER BY time) OR is_stale = true) ORDER BY time DESC LIMIT 50"
        }
      ],
      "title": "Registro de Eventos (ultimas 24h)",
      "type": "table"
